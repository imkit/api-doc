{
  "id": "imkit-api-environment",
  "name": "IMKit API",
  "_postman_variable_scope": "environment",
  "values": [
    {
      "key": "domain",
      "value": "https://your-app.imkit.io",
      "type": "default",
      "enabled": true,
      "description": "Chat Server base URL, e.g. https://myapp.imkit.io"
    },
    {
      "key": "apiKey",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "IM-API-KEY — server-side admin key (from Dashboard > Backend API Key)"
    },
    {
      "key": "clientKey",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "IM-CLIENT-KEY — client/SDK key (from Dashboard > Client Key)"
    },
    {
      "key": "token",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "IM-Authorization — user access token (issued via Create/Update User API)"
    },
    {
      "key": "roomId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Target room ID for room/message operations"
    },
    {
      "key": "clientId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Target user/client ID"
    },
    {
      "key": "messageId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Target message ID"
    }
  ]
}
